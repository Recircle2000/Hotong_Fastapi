# Test your FastAPI endpoints

GET http://127.0.0.1:8000/
Accept: application/json

###

GET http://127.0.0.1:8000/hello/User
Accept: application/json

###

# 공지사항 API 테스트

# 공지사항 목록 조회
GET http://127.0.0.1:8000/notices/
Accept: application/json

###

# 가장 최근 공지사항 1개 조회
GET http://127.0.0.1:8000/notices/latest
Accept: application/json

###

# 공지사항 생성
POST http://127.0.0.1:8000/notices/
Content-Type: application/json

{
  "title": "테스트 공지사항",
  "content": "이것은 테스트 공지사항입니다.",
  "is_pinned": true
}

###

# 특정 공지사항 조회 (생성 후 ID 값을 아래에 넣으세요)
GET http://127.0.0.1:8000/notices/1
Accept: application/json

###

# 공지사항 수정 (ID 값을 적절히 변경하세요)
PUT http://127.0.0.1:8000/notices/1
Content-Type: application/json

{
  "title": "수정된 공지사항",
  "content": "이 내용은 수정되었습니다.",
  "is_pinned": false
}

###

# 공지사항 삭제 (ID 값을 적절히 변경하세요)
DELETE http://127.0.0.1:8000/notices/1

###
